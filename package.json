{
    "name": "llm-chat",
    "version": "0.1.1",
    "description": "LLM conversation package focused on LM Studio local models",
    "license": "MIT",
    "sideEffects": false,
    "files": [
        "dist/src/",
        "README.md",
        "LICENSE",
        "docs/"
    ],
    "author": "Johannes B. Latzel",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/johanneslatzel/llm-chat.git"
    },
    "bugs": {
        "url": "https://github.com/johanneslatzel/llm-chat/issues"
    },
    "homepage": "https://github.com/johanneslatzel/llm-chat#readme",
    "keywords": [
        "llm",
        "chat",
        "openai",
        "typescript",
        "streaming",
        "tools",
        "hooks"
    ],
    "engines": {
        "node": ">=18"
    },
    "type": "module",
    "main": "./dist/src/index.js",
    "types": "./dist/src/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/src/index.d.ts",
            "import": "./dist/src/index.js"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "lint": "eslint . --max-warnings 0",
        "format": "prettier --write src",
        "test": "vitest --exclude 'dist/**'",
        "test:coverage": "vitest run --coverage --exclude 'dist/**'",
        "docs": "docker run --rm -it -p 8000:8000 -v $PWD:/docs squidfunk/mkdocs-material",
        "prepare": "husky"
    },
    "lint-staged": {
        "src/**/*.ts": [
            "prettier --write",
            "eslint --max-warnings 0 --no-warn-ignored",
            "vitest related --run"
        ],
        "src/**": [
            "git add docs/"
        ]
    },
    "dependencies": {
        "async-mutex": "^0.5.0",
        "openai": "^4.86.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.24.0",
        "@types/node": "^22.19.19",
        "@typescript-eslint/eslint-plugin": "^8.60.0",
        "@typescript-eslint/parser": "^8.60.0",
        "@vitest/coverage-v8": "^4.1.8",
        "concurrently": "^9.1.2",
        "eslint": "^9.24.0",
        "eslint-config-prettier": "^10.1.2",
        "eslint-plugin-n": "^17.17.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.1",
        "prettier": "^3.5.3",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    }
}
