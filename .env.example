# LLM Chat — Configuration (example reference)
# Copy to .env and fill in your values.
# Required vars are uncommented; optional ones are commented out with defaults shown.

# --- Connection (required) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_CHAT_OPENAI_DEFAULT_MODEL=

# --- Chat Service ---
# LLM_CHAT_MAX_TOOL_CALL_ROUNDS=10                # default: 10

# --- OpenAI config overrides ---
# LLM_CHAT_OPENAI_TEMPERATURE=                    # unset → OpenAI API default
# LLM_CHAT_OPENAI_MAX_TOKENS=                     # unset → no limit
# LLM_CHAT_OPENAI_MAX_COMPLETION_TOKENS=          # unset → no limit
# LLM_CHAT_OPENAI_TOP_P=                          # unset → OpenAI API default

# --- Prompts ---
# LLM_CHAT_SYSTEM_PROMPT=                         # path to a custom system prompt file
# LLM_CHAT_USER_PROMPTS=                          # comma-separated paths to initial user message files

